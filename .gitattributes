# Keep text files readable and stable across Windows/Linux checkouts.
* text=auto

# Source, config, and docs are normalized to LF.
*.md text eol=lf
*.java text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.groovy text eol=lf
*.py text eol=lf
*.cs text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.tpl text eol=lf
*.Dockerfile text eol=lf
*.Jenkinsfile text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf

# Windows entrypoints keep CRLF for direct shell execution.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary artifacts must never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.exe binary
*.dll binary
*.pdb binary
*.jar binary
*.keystore binary
*.p12 binary