APP_VERSION=two-vm-local

PORTONE_SECRET=
JWT_KEY=REPLACE_WITH_BASE64URL_32_BYTE_SECRET
JWT_EXPIRE=86400000

ADMIN_EMAIL=admin@fileinnout.local
ADMIN_NAME=Administrator
ADMIN_ROLE=ROLE_ADMIN
ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
# Optional semicolon-separated extra admins:
# ADMIN_ADDITIONAL_USERS=ops@fileinnout.local|OpsAdmin|REPLACE_WITH_OPS_PASSWORD
ADMIN_ADDITIONAL_USERS=

APP_FRONTEND_URL=http://192.168.35.151
APP_BACKEND_URL=http://192.168.35.151/api
APP_SECURE_COOKIE=false
APP_ADMIN_ONLY=true
REALTIME_UPSTREAM=192.168.35.152:1234

DB_SERVER=org.mariadb.jdbc.Driver
DB_URL=jdbc:mariadb://192.168.35.152:3306/web
DB_ID=root
DB_PASS=REPLACE_WITH_DB_PASSWORD

REDIS_HOST=192.168.35.152
REDIS_PORT=6379
REDIS_SENTINEL_MASTER=
REDIS_SENTINEL_NODES=
REDIS_PASSWORD=

GOOGLE_CLIENT_ID=dummy-google-client-id
GOOGLE_CLIENT_SECRET=dummy-google-client-secret
NAVER_CLIENT_ID=dummy-naver-client-id
NAVER_CLIENT_SECRET=dummy-naver-client-secret
CLIENT_ID=dummy-kakao-client-id
CLIENT_SECRET=dummy-kakao-client-secret

MAIL_PORT=587
MAIL_ID=
MAIL_PASS=

STORAGE_PROVIDER=minio
MINIO_API=http://192.168.35.152:9000
MINIO_PUBLIC_API=http://192.168.35.152:9000
MINIO_NAME=REPLACE_WITH_MINIO_USER
MINIO_SECRET=REPLACE_WITH_MINIO_PASSWORD
MINIO_CLOUD_BUCKET=fileinnout
MINIO_WORKSPACE_BUCKET=fileinnout-workspace
MINIO_REGION=ap-northeast-2

S3AMAZON_API=https://s3.ap-northeast-2.amazonaws.com
S3AMAZON_PUBLIC_API=https://s3.ap-northeast-2.amazonaws.com
S3AMAZON_NAME=
S3AMAZON_SECRET=
S3AMAZON_CLOUD_BUCKET=
S3AMAZON_WORKSPACE_BUCKET=
S3AMAZON_REGION=ap-northeast-2
